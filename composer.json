{
  "name": "alxarafe/resource-eloquent",
  "description": "Eloquent ORM adapter for alxarafe/resource-controller. Implements RepositoryContract, QueryContract, and TransactionContract using Illuminate Database.",
  "version": "0.1.0",
  "type": "library",
  "license": "GPL-3.0-or-later",
  "keywords": ["eloquent", "orm", "adapter", "crud", "resource-controller", "illuminate"],
  "authors": [
    {
      "name": "Rafael San José",
      "email": "rsanjose@alxarafe.com",
      "homepage": "https://alxarafe.es",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "alxarafe/resource-controller": "^0.1.1",
    "illuminate/database": "^10.0 || ^11.0 || ^12.0"
  },
  "autoload": {
    "psr-4": {
      "Alxarafe\\ResourceEloquent\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Alxarafe\\ResourceEloquent\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "phpstan/phpstan": "^2.1",
    "vimeo/psalm": "^6.0"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true
  }
}
